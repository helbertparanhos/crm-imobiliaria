# ==========================================================================
# CRM Imobiliária — variáveis de ambiente (EXEMPLO)
# Copie para `.env` e para `.env.local` conforme o uso. NUNCA comite o .env real.
# ==========================================================================

# --------------------------------------------------------------------------
# FRONTEND (Vite) — só chaves PÚBLICAS podem ter o prefixo VITE_
# Preenchidas na FASE 3 (quando o Supabase entrar). Na Fase 1 ficam vazias.
# --------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=          # publishable/anon key (pública, protegida por RLS)

# Alterna a fonte de dados: "mock" (Fase 1) ou "supabase" (Fase 3+)
VITE_DATA_SOURCE=mock

# --------------------------------------------------------------------------
# MCPs (usados pelo Cursor / Claude Code — .cursor/mcp.json referencia estes)
# Estes NÃO vão para o bundle do front. São credenciais de ferramenta local.
# --------------------------------------------------------------------------

# Supabase
SUPABASE_PROJECT_REF=            # ex.: abcdefghijklmno
SUPABASE_ACCESS_TOKEN=           # Personal Access Token (Supabase > Account > Access Tokens)

# GitHub
GITHUB_PAT=                      # PAT com escopo repo (fine-grained de preferência)

# EasyPanel
EASYPANEL_URL=https://seu-painel.exemplo.com
EASYPANEL_TOKEN=                 # API token do EasyPanel

# n8n
N8N_API_KEY=                     # Settings > API no n8n (n8neditor.strat.tec.br)

# Cloudflare — usa OAuth no primeiro connect (mcp.cloudflare.com). Sem token aqui.

# --------------------------------------------------------------------------
# NUNCA colocar aqui: SUPABASE_SERVICE_ROLE_KEY.
# A service_role ignora RLS e não pode encostar no frontend em hipótese nenhuma.
# --------------------------------------------------------------------------
